# pyenv
.python-version

# pipenv
#   According to pypa/pipenv#1173, pipenv managed virtualenvs are usually
#   located under ~/.local/share/virtualenvs/. However, if the `PIPENV_VENV_IN_PROJECT`
#   environment variable is set, pipenv will create the virtualenv in the project
#   root/venv.
# .venv

# Poetry
#   Poetry-managed virtualenvs are usually located under {cache-dir}/virtualenvs/.
#   However, if `virtualenvs.in-project` is set to `true`, poetry will create the
#   virtualenv in the project root/venv.
.venv/
venv/
ENV/
env/

